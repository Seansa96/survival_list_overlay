<Window x:Class="survival_list_overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        SizeToContent="Height"
        Width="560"
        MouseDown="Window_MouseDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#B0111111" />
        <SolidColorBrush x:Key="OverlayBandBrush" Color="#331E1E1E" />
        <SolidColorBrush x:Key="OverlayRowBrush" Color="#22181818" />
        <SolidColorBrush x:Key="OverlayRowBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFD8D8D8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFAAAAAA" />

        <Style x:Key="PrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EntryRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource OverlayRowBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayRowBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="TransparentListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          MouseEnter="RootGrid_MouseEnter"
          MouseLeave="RootGrid_MouseLeave">

        <Border x:Name="TitleBar"
                Background="#66000000"
                Height="30"
                VerticalAlignment="Top"
                CornerRadius="8,8,0,0"
                Visibility="Collapsed">
            <DockPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource PrimaryTextStyle}"
                           Margin="10,0" />
                <Button Content="X"
                        DockPanel.Dock="Right"
                        Click="Close_Click"
                        Width="30"
                        Height="30"
                        Padding="0" />
            </DockPanel>
        </Border>

        <Border Background="{StaticResource OverlayPanelBrush}"
                CornerRadius="12"
                Padding="12"
                Margin="0,30,0,0">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource OverlayBandBrush}"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding HeaderText}"
                                       Style="{StaticResource PrimaryTextStyle}" />
                            <TextBlock Text="{Binding EntryCountText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  Width="104"
                                  Height="24"
                                  Margin="8,0,0,0"
                                  ItemsSource="{Binding SortModes}"
                                  SelectedItem="{Binding SelectedSortMode}" />
                        <ToggleButton Grid.Column="2"
                                      Content="Favs"
                                      Style="{StaticResource CompactToggleStyle}"
                                      IsChecked="{Binding ShowFavoritesOnly}"
                                      ToolTip="Show favorite entries" />
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Top"
                        Background="{StaticResource OverlayBandBrush}"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,8">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="SearchBox_KeyDown"
                                     MinWidth="260"
                                     Height="24" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewTargetQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="6,0,0,0"
                                     Height="24"
                                     HorizontalContentAlignment="Center" />
                            <Button Grid.Column="2"
                                    Content="Add"
                                    Height="24"
                                    Margin="6,0,0,0"
                                    Command="{Binding AddSelectedResultCommand}" />
                        </Grid>

                        <ListBox DockPanel.Dock="Bottom"
                                 ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedSearchResult}"
                                 Height="76"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource TransparentListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EntryTypeLabel}"
                                                   Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Style="{StaticResource PrimaryTextStyle}"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Summary}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Grid>
                    <TextBlock Text="{Binding EmptyStateText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListBox ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry}"
                             MinHeight="112">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource TransparentListBoxStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EntryRowBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="128" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource PrimaryTextStyle}" />
                                            <TextBlock Text="{Binding EntryTypeLabel}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ProgressText}"
                                                       Style="{StaticResource PrimaryTextStyle}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding RemainingText}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="-"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    Margin="0"
                                                    Command="{Binding DecrementCommand}"
                                                    ToolTip="Decrease current quantity" />
                                            <Button Content="+"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    Command="{Binding IncrementCommand}"
                                                    ToolTip="Increase current quantity" />
                                            <TextBox Text="{Binding Priority, UpdateSourceTrigger=LostFocus}"
                                                     Width="32"
                                                     Height="24"
                                                     Margin="4,0,0,0"
                                                     HorizontalContentAlignment="Center"
                                                     ToolTip="Priority" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <Button Content="F"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    Command="{Binding ToggleFavoriteCommand}"
                                                    ToolTip="Toggle favorite" />
                                            <Button Content="P"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    Command="{Binding ToggleStickyCommand}"
                                                    ToolTip="Toggle sticky" />
                                            <Button Content="X"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    Command="{Binding DataContext.RemoveEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove entry" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Margin="16,6,0,0">
                                            <Grid Visibility="{Binding IsRecipe, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="56" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding IngredientSummary}"
                                                           Style="{StaticResource MutedTextStyle}" />
                                                <Button Grid.Column="1"
                                                        Content="{Binding ExpandText}"
                                                        Height="22"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding ToggleExpandedCommand}"
                                                        ToolTip="Expand recipe ingredients" />
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding IngredientRows}"
                                                          Margin="14,4,0,0">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="72" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}"
                                                                       Style="{StaticResource SecondaryTextStyle}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ProgressText}"
                                                                       Style="{StaticResource MutedTextStyle}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding RemainingQuantity, StringFormat=Need: {0}}"
                                                                       Style="{StaticResource MutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
